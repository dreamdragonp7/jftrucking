# ============================================
# JFT - J Fudge Trucking
# Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# --- Supabase ---
# Project URL from Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# --- QuickBooks Online ---
# OAuth app credentials from Intuit Developer
QB_CLIENT_ID=
QB_CLIENT_SECRET=
# "sandbox" for development, "production" for live
QB_ENVIRONMENT=sandbox
# Must match the redirect URI configured in the Intuit app
QB_REDIRECT_URI=http://localhost:3000/api/qb/callback
# Company ID (Realm ID) from QuickBooks
QB_REALM_ID=

# --- Twilio ---
# Account credentials from Twilio console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Phone number in E.164 format (+1XXXXXXXXXX)
TWILIO_PHONE_NUMBER=

# --- Resend ---
# API key from Resend dashboard
RESEND_API_KEY=

# --- Cron Jobs ---
# Secret for authenticating Vercel Cron requests
CRON_SECRET=

# --- App ---
# Base URL for the application
NEXT_PUBLIC_APP_URL=http://localhost:3000
